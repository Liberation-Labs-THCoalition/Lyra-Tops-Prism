# arXiv MCP Server Configuration

# === Storage ===
# Base directory for papers and metadata (default: ~/.arxiv-mcp)
ARXIV_DATA_DIR=

# === Semantic Scholar (optional, for citation graph) ===
# Free API key at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# === Rate Limiting ===
# Seconds between arXiv API requests (default: 3, per arXiv policy)
ARXIV_RATE_LIMIT_SECONDS=3
